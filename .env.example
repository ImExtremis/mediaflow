# ============================================================
# MediaFlow Environment Configuration
# Copy this file to .env and edit before running install.sh
# ============================================================

# System user IDs (run: id -u && id -g to find yours)
PUID=1000
PGID=1000

# Timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=UTC

# ─── Paths ───────────────────────────────────────────────────
# Where your unified media and downloads will live (TRaSH Guides standard)
# This directory will contain /data/media and /data/torrents
DATA_PATH=/mnt/data
# Config files for arr services
CONFIG_PATH=./appdata

# ─── Service Ports ───────────────────────────────────────────
DASHBOARD_PORT=8080
SONARR_PORT=8989
RADARR_PORT=7878
PROWLARR_PORT=9696
QBIT_PORT=8082
JELLYFIN_PORT=8096
BAZARR_PORT=6767
SONARR_ANIME_PORT=8990
JELLYSEERR_PORT=5055
TDARR_UI_PORT=8265
TDARR_SERVER_PORT=8266

# ─── API Keys (auto-generated by install.sh if blank) ────────
SONARR_API_KEY=
RADARR_API_KEY=
PROWLARR_API_KEY=
JELLYFIN_API_KEY=
JWT_SECRET=

# ─── TMDB (For Trending Feature) ─────────────────────────────
# Get a free key from themoviedb.org/settings/api
TMDB_API_KEY=

# ─── Service Toggles ─────────────────────────────────────────
# Enable optional heavy services (true/false)
SONARR_ANIME_ENABLED=true
TDARR_ENABLED=true
BAZARR_ENABLED=true

# ─── qBittorrent Credentials ─────────────────────────────────
QBIT_USER=admin
QBIT_PASS=adminpassword

# ─── Dashboard Backend ───────────────────────────────────────
BACKEND_PORT=3001
NODE_ENV=production
